<Window x:Class="Telemetry.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Telemetry.Dashboard"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="Telemetry Dashboard" Height="600" Width="900">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="API base URL:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="BaseUrlBox" Width="320" Padding="4,2" VerticalContentAlignment="Center"
                     ToolTip="e.g. http://localhost:5244"/>
            <Button x:Name="RefreshButton" automation:AutomationProperties.AutomationId="RefreshButton" Content="Refresh runs" Margin="8,0,0,0" Padding="12,4" Click="RefreshButton_OnClick"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="Gray"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
            <TextBlock Text="Runs (select one to view timeline and actions)" FontWeight="SemiBold"/>
        </Border>

        <DataGrid x:Name="RunsGrid" automation:AutomationProperties.AutomationId="RunsGrid" Grid.Row="2" Margin="0,0,0,8"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  SelectionChanged="RunsGrid_SelectionChanged" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="90"/>
                <DataGridTextColumn Header="Sample" Binding="{Binding SampleId}" Width="120"/>
                <DataGridTextColumn Header="State" Binding="{Binding CurrentState}" Width="100"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="DetailTitle" automation:AutomationProperties.AutomationId="DetailTitle" Text="Run details" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ListBox x:Name="TimelineList" Grid.Row="1" Margin="0,0,0,8"
                     DisplayMemberPath="Display"
                     BorderThickness="1" BorderBrush="LightGray"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button x:Name="QueueButton" automation:AutomationProperties.AutomationId="QueueButton" Content="Queue" Margin="0,0,8,0" Padding="12,4" Click="QueueButton_OnClick" IsEnabled="False"/>
                <Button x:Name="StartButton" Content="Start" Margin="0,0,8,0" Padding="12,4" Click="StartButton_OnClick" IsEnabled="False"/>
                <Button x:Name="CancelButton" Content="Cancel" Margin="0,0,8,0" Padding="12,4" Click="CancelButton_OnClick" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
